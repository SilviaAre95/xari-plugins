{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep|Glob|NotebookRead",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/auto-approve-reads.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/loop-gate.sh" }
        ]
      }
    ]
  }
}
